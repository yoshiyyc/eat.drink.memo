rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shops: read-only for everyone; only allow updating reviewCount via authenticated users
    match /shops/{shopId} {
      allow read: if true;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewCount']);
      allow create, delete: if false;
    }

    // Drinks: read-only for everyone
    match /drinks/{drinkId} {
      allow read: if true;
      allow write: if false;
    }

    // Reviews: anyone can read; authenticated users can create;
    // only owner can update or delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // User profiles: anyone can read; only self can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Suggestions: anyone can create (guests allowed); only admin can read/delete
    match /suggestions/{suggestionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email == 'yoshi.wind.wing@gmail.com';
    }
  }
}
